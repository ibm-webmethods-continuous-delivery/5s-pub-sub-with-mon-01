# HOST related variables
PSM_TEST_HOST_PORT_PREFIX=462

# GUEST related variables
PSM_TEST_GUEST_IS_HOME=/opt/softwareag/IntegrationServer

# Reusability variables
# The container must be a build of this project, not a generic MSR or IS
PSM_TEST_PUBLISHER_CONTAINER_IMAGE_REPOSITORY=host.docker.internal:44450/demo/5s-publisher
PSM_TEST_PUBLISHER_CONTAINER_IMAGE_TAG=latest

PSM_TEST_SUBSCRIBER_CONTAINER_IMAGE_REPOSITORY=host.docker.internal:44450/demo/5s-subscriber
PSM_TEST_SUBSCRIBER_CONTAINER_IMAGE_TAG=latest

PSM_TEST_UM_CONTAINER_IMAGE=ibmwebmethods.azurecr.io/universalmessaging-server
PSM_TEST_UM_CONTAINER_TAG=11.1.3

# Runtime options
PSM_TEST_GUEST_IS_ADMIN_PWD=manage02

PSM_TEST_GUEST_MOUNT_POINT_APPLICATION_PROPERTIES=/mnt/application.properties
PSM_TEST_GUEST_MOUNT_POINT_LICENSE_FILE=/mnt/msr-license.xml
PSM_TEST_GUEST_MOUNT_POINT_UM_REALM_DATA=/opt/softwareag/UniversalMessaging/server/umserver/data/
PSM_TEST_GUEST_MOUNT_POINT_UM_REALM_LOGS=/opt/softwareag/UniversalMessaging/server/umserver/logs/
PSM_TEST_GUEST_MOUNT_POINT_UM_REALM_USERS=/opt/softwareag/common/conf/

# JMeter tests parameters
MIN_USERS_NO=4
USER_NO_INCREMENT=5
MAX_USERS_NO=40

LOOP_COUNT=20

# API
API_HOST=msr-test-01-pub
API_PORT=5555
API_URI=/rad/wmDemo.Mockup.restResource:genericResource/genericResource
API_PROTOCOL=http

# API
API_USER=Administrator
API_USER_PWD=${PSM_TEST_GUEST_IS_ADMIN_PWD}

GF_SMTP_ENABLED=true
GF_SMTP_HOST=your-smtp-server:587
GF_SMTP_USER=your-username
GF_SMTP_PASSWORD=your-password
GF_SMTP_FROM_ADDRESS=grafana@your-domain.com
